# --- Reasoning (LLM) ---
# If no key for the active provider, the reason node falls back to the
# deterministic engine (loop still runs).
CEDAR_LLM_PROVIDER=groq          # groq (default) | anthropic
GROQ_API_KEY=                    # get one free at console.groq.com
CEDAR_MODEL=llama-3.3-70b-versatile   # cheaper: llama-3.1-8b-instant
CEDAR_MAX_TOKENS=512
CEDAR_LLM_GATE=1                 # 1 = skip the model on clear-HOLD cycles, during cooldown,
                                 #     and once the daily budget is spent (saves credits)
CEDAR_LLM_DAILY_BUDGET=0         # max model calls/day (0 = unlimited); e.g. 200
# To use Claude instead: CEDAR_LLM_PROVIDER=anthropic, ANTHROPIC_API_KEY=…,
# CEDAR_MODEL=claude-haiku-4-5
# ANTHROPIC_API_KEY=

# --- Data source / signer selection ---
# mock (default) = fully offline demo/dev; casper/csprclick = real seams.
CEDAR_DATA_SOURCE=mock          # mock | casper
CEDAR_SIGNER=mock               # mock | casper (real server-side signing) | csprclick (alias)
CASPER_CALL_PAYMENT=5000000000  # motes for a reallocate call (5 CSPR)
CEDAR_CONFIRM_TX=0              # 1 = block until the reallocate deploy executes on-chain
CASPER_CLIENT_BIN=              # optional override; defaults to ~/.cargo/bin/casper-client

# --- Casper chain (real mode) ---
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN=casper-test
CASPER_SECRET_KEY="./Account 1_secret_key.pem"   # quote if the path has spaces
VAULT_ROUTER_HASH=hash-dc10056192be60ae8db84e0b24e27629aec44381ba41b3bebfc89501b1828135  # v2 (owner-gated)
CASPER_EXPLORER_TX=https://testnet.cspr.live/deploy/

# --- Real MCP endpoints (real mode) ---
# CSPR.trade MCP: public, no key. Serves testnet pools (test tokens present).
CSPR_TRADE_MCP_URL=https://mcp.cspr.trade/mcp
#CASPER_GAS_ESTIMATE=           # CSPR; defaults to CASPER_CALL_PAYMENT/1e9 (the real charge)
# Casper MCP (community, msanlisavas) — chain reads + intended 2nd APY source.
# Needs a cspr.cloud key; X-Casper-Network defaults to testnet. Until set, the
# two-provider cross-source check mirrors the primary reading (documented no-op).
CASPER_MCP_URL=https://mcp.testnet.cspr.cloud/mcp   # mainnet: https://mcp.cspr.cloud/mcp
CSPR_CLOUD_API_KEY=
X_CASPER_NETWORK=testnet

# --- Loop / API ---
CEDAR_INTERVAL=120              # seconds between cycles
CEDAR_AUTOSTART=1               # 1 = start loop on API boot
CEDAR_DB=./data/cedar.db
# CEDAR_CORS_ORIGINS=*          # comma-separated allow-list; * = open (default)
# Admin gate: if set, write/control endpoints (policy, pause, resume, onboard,
# run-once, demo) require this token via `Authorization: Bearer <t>` or
# `X-Admin-Token: <t>`. Unset = open (local dev / interactive public demo).
# CEDAR_ADMIN_TOKEN=
